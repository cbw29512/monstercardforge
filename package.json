{
  "name": "dm-forge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:static",
    "test:static": "node --test tests/*.test.mjs",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:production": "npm run test:static && npm run test:browser"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1"
  },
  "engines": {
    "node": ">=20"
  }
}
